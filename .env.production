# .env.production
# Production environment variable template for student-ai-automation.
#
# ⚠️  DO NOT commit real secrets to version control.
#     Copy this file to .env.production.local and fill in real values,
#     OR set these variables directly as Cloud Run environment variables /
#     Secret Manager secrets.
#
# When using Cloud Run, set these via:
#   gcloud run deploy ... --set-env-vars KEY=VALUE
#   gcloud run deploy ... --set-secrets GEMINI_API_KEY=gemini-api-key:latest

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PYTHONUNBUFFERED=1
PORT=3000

# ── AI / Gemini ───────────────────────────────────────────────────────────────
# Required. Obtain from https://aistudio.google.com/apikey
# Recommended: store in Secret Manager and reference with --set-secrets.
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (data persists within the container instance).
# For durable storage across restarts use Cloud SQL:
#   DATABASE_URL=postgresql+asyncpg://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=sqlite:///./data/ridhi.db

# ── Service URL ───────────────────────────────────────────────────────────────
# Set this to your Cloud Run service URL after first deployment.
# Example: https://student-ai-automation-xxxxx-uc.a.run.app
APP_URL=https://student-ai-automation-xxxxx.run.app

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_GMAIL_INTEGRATION=true
ENABLE_TELEGRAM_INTEGRATION=true
ENABLE_LINKEDIN_ASSIST=true
ENABLE_WHATSAPP_SIMULATION=true
ENABLE_RESUME_AUTOMATION=true
ENABLE_TRUTHGRID=true
ENABLE_DASHBOARD=true
