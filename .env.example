# Core
GEMINI_API_KEY="replace-with-your-key"
DATABASE_URL="sqlite:///./data/ridhi.db"

# WhatsApp lead automation
WHATSAPP_DEFAULT_COUNTRY_CODE="91"
WHATSAPP_FOLLOWUP_DELAY_HOURS="24"
WHATSAPP_INITIAL_TEMPLATE="Hi {name}, thanks for contacting us. We received your requirement: {requirement}."
WHATSAPP_FOLLOWUP_TEMPLATE="Hi {name}, quick follow-up on your requirement: {requirement}. Reply here and we can help."

# Content scheduler
CONTENT_REMINDER_MINUTES="30"
CONTENT_SCHEDULING_TOLERANCE_MINUTES="1"

# AI auto-responder
AUTO_RESPONDER_CHANNEL_ALLOWLIST="whatsapp,instagram,email,website"
AUTO_RESPONDER_ESCALATION_KEYWORDS="refund,cancel,complaint,lawyer,urgent,human"
AUTO_RESPONDER_DEFAULT_CONTEXT="You are a helpful SME support assistant. Keep replies concise and action-oriented."
AUTO_RESPONDER_MAX_INCOMING_LENGTH="2000"
