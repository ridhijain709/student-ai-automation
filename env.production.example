# ─────────────────────────────────────────────────────────────────────────────
# env.production.example
# Production environment variables for the Ridhi Command Center.
#
# Copy this file to .env and fill in real values before deploying.
# NEVER commit a .env file with real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Required. Obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Application URL ───────────────────────────────────────────────────────────
# Full public URL of the deployed service, e.g. the Cloud Run service URL.
# Used for OAuth callbacks, self-referential links, and CORS allow-list.
APP_URL=https://ridhi-command-center-<hash>-uc.a.run.app

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite path (default). For Cloud Run use a persistent volume or Cloud SQL.
# Example SQLite path inside the container:
DATABASE_URL=sqlite:////app/data/ridhi.db
# Example Cloud SQL (PostgreSQL) connection string:
# DATABASE_URL=postgresql+psycopg2://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Node.js / Express server ──────────────────────────────────────────────────
# Port the Express static server listens on (Cloud Run expects 3000 or $PORT).
PORT=3000
NODE_ENV=production

# ── Python / FastAPI backend ──────────────────────────────────────────────────
# Internal port the FastAPI/Uvicorn process listens on.
BACKEND_PORT=8000

# ── CORS allowed origins ──────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the backend API.
# In production, restrict this to your actual frontend URL.
ALLOWED_ORIGINS=https://ridhi-command-center-<hash>-uc.a.run.app

# ── Google Cloud (deployment only – not baked into the image) ────────────────
# GCP project ID used by cloud-run-deploy.sh and cloudbuild.yaml
# GCP_PROJECT_ID=my-gcp-project
# GCP deployment region
# GCP_REGION=us-central1
